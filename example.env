# 1. Create .env file in root directory of project
# 2. Insert this fields to your file
# 3. Replace placeholders with your data

# Database
DB_NAME=DB_NAME
DB_USER=DB_USER
DB_PASSWORD=DB_PASSWORD
DB_HOST=DB_HOST
DB_PORT=DB_PORT

# Frontend
VITE_BACKEND_URL=your_url
# 1 - to install frontend precommit
# 0 - to don`t install frontend precommit
FRONTEND_LINTING=

# Django
DJANGO_ALLOWED_HOSTS=localhost
SECRET_KEY=KEY
DJANGO_DEBUG=

# Bot
TOKEN=YOUR_TOKEN
WEB_APP_URL=YOUR_URL