FROM golang:1.25-alpine AS build

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/cs-smokes-backend ./cmd/server

FROM alpine:3.20

WORKDIR /backend

RUN adduser -D service-user \
    && mkdir -p /backend/media \
    && chown -R service-user:service-user /backend

COPY --from=build /out/cs-smokes-backend /usr/local/bin/cs-smokes-backend

EXPOSE 8000

USER service-user

CMD ["cs-smokes-backend"]
