# This file will not override compose configuration
# Insert ONLY not sensitive information in this file
DEBUG=True
DJANGO_ALLOWED_HOSTS=your_allowed_hosts
SECRET_KEY=your_secret_key
DATABASE_URL=your_database_url
ALLOWED_HOSTS=your_allowed_hosts
DB_NAME=example_name
DB_USER=example_user
DB_PASSWORD=example_password
DB_HOST=example_host
DB_PORT=5432
BACKEND_SERVER=http://localhost:3000/api
BACKEND_PREFIX=/api
#Allowed hosts for CORS and CSRF
ALLOWED_ORIGINS=http://localhost:3000,https://localhost:3000,http://localhost:9999,http://localhost:8080,https://XXX.ngrok-free.app

# Not gonna be passed from compose file
DJANGO_SETTINGS_MODULE=backend.settings
PYTHONDONTWRITEBYTECODE=1
PYTHONUNBUFFERED=1