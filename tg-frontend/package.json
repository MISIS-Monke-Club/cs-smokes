{
    "name": "vite-react-starter",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "main": "src/app/main.tsx",
    "scripts": {
        "dev": "npx vite",
        "host": "npx vite --host",
        "build": "npx vite build",
        "preview": "npx vite preview",
        "lint": "npx eslint ./src && npx stylelint './src/**/*.scss'",
        "lint:auto-fix": "npx eslint ./src --fix && npx stylelint './src/**/*.scss' --fix",
        "lint:format": "npx prettier ./src --write",
        "prepare": "cd .. && husky ./tg-frontend/.husky || true",
        "storybook": "VITE_BACKEND_URL=http://localhost:3000/api VITE_TG_INIT_DATA=123 VITE_IN_TG_ENVIRONMENT=false storybook dev -p 6006",
        "test:prepare": "npx playwright install",
        "test:prepare-ci": "npx playwright install --with-deps",
        "test": "VITE_BACKEND_URL=http://localhost:3000/api VITE_TG_INIT_DATA=123 VITE_IN_TG_ENVIRONMENT=false npx vitest run",
        "type-check": "tsc --noEmit --pretty --skipLibCheck -p tsconfig.json",
        "test-storybook": "VITE_BACKEND_URL=http://localhost:3000/api VITE_TG_INIT_DATA=123 VITE_IN_TG_ENVIRONMENT=false npx test-storybook",
        "build-storybook": "VITE_BACKEND_URL=http://localhost:3000/api VITE_TG_INIT_DATA=123 VITE_IN_TG_ENVIRONMENT=false storybook build"
    },
    "dependencies": {
        "@radix-ui/react-dialog": "^1.1.14",
        "@radix-ui/react-label": "^2.1.6",
        "@radix-ui/react-select": "^2.2.4",
        "@radix-ui/react-slot": "^1.2.2",
        "@radix-ui/react-switch": "^1.2.4",
        "@radix-ui/react-tabs": "^1.1.12",
        "@reduxjs/toolkit": "^2.5.0",
        "@tailwindcss/vite": "^4.0.10",
        "@tanstack/react-query": "^5.67.1",
        "@tanstack/react-query-devtools": "^5.76.1",
        "@vitejs/plugin-react": "^4.3.4",
        "axios": "^1.8.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "dotenv": "^16.4.7",
        "embla-carousel-react": "^8.6.0",
        "lucide-react": "^0.477.0",
        "path": "^0.12.7",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-redux": "^9.2.0",
        "react-router-dom": "^6.26.2",
        "sonner": "^2.0.1",
        "stylelint-config-standard": "^38.0.0",
        "tailwind-merge": "^3.0.2",
        "tailwindcss": "^4.0.10",
        "tailwindcss-animate": "^1.0.7",
        "use-debounce": "^10.0.4",
        "vite": "^6.2.4",
        "zod": "^3.24.1"
    },
    "devDependencies": {
        "@chromatic-com/storybook": "^3.2.5",
        "@conarti/eslint-plugin-feature-sliced": "^1.0.5",
        "@storybook/addon-essentials": "^8.6.12",
        "@storybook/addon-mdx-gfm": "^8.6.12",
        "@storybook/blocks": "^8.6.12",
        "@storybook/experimental-addon-test": "^8.6.12",
        "@storybook/manager-api": "^8.6.12",
        "@storybook/react": "^8.6.12",
        "@storybook/react-vite": "^8.6.12",
        "@storybook/test": "^8.6.12",
        "@storybook/test-runner": "^0.22.0",
        "@storybook/theming": "^8.6.12",
        "@types/node": "^22.13.9",
        "@types/react": "^18.3.11",
        "@types/react-dom": "^18.3.1",
        "@vitest/browser": "^3.0.8",
        "@vitest/coverage-v8": "^3.0.8",
        "@vitest/ui": "^3.0.9",
        "chromatic": "^11.27.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-import-resolver-typescript": "^3.9.0",
        "eslint-plugin-boundaries": "^5.0.0",
        "eslint-plugin-import": "^2.31.0",
        "eslint-plugin-prettier": "^5.2.3",
        "eslint-plugin-react": "^7.37.4",
        "eslint-plugin-react-hooks": "^5.2.0",
        "globals": "^15.12.0",
        "husky": "^9.1.7",
        "lint-staged": "^15.5.0",
        "msw": "^2.7.3",
        "msw-storybook-addon": "^2.0.4",
        "playwright": "^1.51.0",
        "prettier": "^3.3.3",
        "sass": "^1.79.2",
        "sass-embedded": "^1.79.1",
        "scss": "^0.2.4",
        "storybook": "^8.6.12",
        "stylelint": "^16.18.0",
        "stylelint-config-clean-order": "^7.0.0",
        "stylelint-config-standard-scss": "^14.0.0",
        "telegram-webapps": "^8.0.4",
        "typescript": "^5.8.2",
        "typescript-eslint": "^8.13.0",
        "vitest": "^3.1.1"
    },
    "eslintConfig": {
        "extends": [
            "plugin:storybook/recommended"
        ]
    },
    "msw": {
        "workerDirectory": [
            "public"
        ]
    }
}
