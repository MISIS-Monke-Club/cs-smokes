{
  "name": "vite-react-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "src/app/main.tsx",
  "scripts": {
    "dev": "npx vite",
    "host": "npx vite --host",
    "build": "npx vite build",
    "lint": "npx eslint ./src",
    "lint:auto-fix": "npx eslint ./src --fix",
    "lint:format": "npx prettier ./src --write",
    "prepare": "cd .. && husky ./tg-frontend/.husky || true",
    "storybook": "storybook dev -p 6006",
    "test:prepare": "npx playwright install",
    "test": "npx vitest run",
    "type-check": "tsc --noEmit --pretty --skipLibCheck -p tsconfig.json",
    "test-storybook": "npx test-storybook",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.6",
